// Place your key bindings in this file to override the defaults
[
    // Toggle sidebar
    // {
    //     "key": "cmd+b",
    //     "command": "-workbench.action.toggleSidebarVisibility"
    //     // Отключение стандартной комбинации Cmd+B для боковой панели
    // },
    // {
    //     "key": "ctrl+b",
    //     "command": "workbench.action.toggleSidebarVisibility"
    //     // Переключение видимости боковой панели (Ctrl+B)
    // },
    
    // Навигация по истории редактора
    {
        "key": "ctrl+o",
        "command": "workbench.action.navigateBack"
        // Навигация назад по истории открытых файлов
    },
    {
        "key": "ctrl+-",
        "command": "-workbench.action.navigateBack"
        // Отключение стандартной навигации назад (Ctrl+-)
    },
    {
        "key": "ctrl+i",
        "command": "workbench.action.navigateForward"
        // Навигация вперед по истории открытых файлов
    },
    {
        "key": "ctrl+shift+-",
        "command": "-workbench.action.navigateForward"
        // Отключение стандартной навигации вперед (Ctrl+Shift+-)
    },
    
    // Настройки
    {
        "key": "cmd+,",
        "command": "workbench.action.openSettingsJson"
        // Открыть settings.json напрямую (вместо GUI настроек)
    },
    {
        "key": "cmd+,",
        "command": "-workbench.action.openSettings"
        // Отключение стандартного открытия GUI настроек
    },
    
    // Множественные курсоры
    {
        "key": "shift+cmd+up",
        "command": "-list.collapseAll",
        "when": "listFocus && !inputFocus"
        // Отключение сворачивания всех элементов списка
    },
    {
        "key": "alt+cmd+up",
        "command": "-editor.action.insertCursorAbove",
        "when": "editorTextFocus"
        // Отключение стандартной вставки курсора выше
    },
    {
        "key": "alt+cmd+down",
        "command": "-editor.action.insertCursorBelow",
        "when": "editorTextFocus"
        // Отключение стандартной вставки курсора ниже
    },
    {
        "key": "shift+cmd+up",
        "command": "editor.action.insertCursorAbove"
        // Вставить курсор на строку выше
    },
    {
        "key": "shift+cmd+down",
        "command": "editor.action.insertCursorBelow"
        // Вставить курсор на строку ниже
    },
    
    // Умное выделение (expand/shrink AST)
    {
        "key": "alt+o",
        "command": "editor.action.smartSelect.expand",
        "when": "editorTextFocus"
        // Расширить выделение (слово → выражение → строка → блок)
    },
    {
        "key": "alt+i",
        "command": "editor.action.smartSelect.shrink",
        "when": "editorTextFocus"
        // Уменьшить область выделения
    },
    
    // Навигация по словам
    // {
    //     "key": "shift+alt+right",
    //     "command": "-cursorWordEndRightSelect",
    //     "when": "textInputFocus"
    //     // Отключение стандартного выделения до конца слова справа
    // },
    // {
    //     "key": "shift+cmd+left",
    //     "command": "cursorWordStartLeft",
    //     "when": "textInputFocus"
    //     // Переместить курсор к началу слова слева
    // },
    // {
    //     "key": "alt+left",
    //     "command": "-cursorWordStartLeft",
    //     "when": "textInputFocus"
    //     // Отключение стандартного перемещения к началу слова (Alt+Left используется для навигации)
    // },
    // {
    //     "key": "shift+alt+right",
    //     "command": "cursorWordEndRight",
    //     "when": "textInputFocus"
    //     // Переместить курсор к концу слова справа
    // },
    // {
    //     "key": "alt+right",
    //     "command": "-cursorWordEndRight",
    //     "when": "textInputFocus"
    //     // Отключение стандартного перемещения к концу слова (Alt+Right используется для навигации)
    // },
    // {
    //     "key": "shift+alt+left",
    //     "command": "-cursorWordStartLeftSelect",
    //     "when": "textInputFocus"
    //     // Отключение стандартного выделения до начала слова слева
    // },
    // {
    //     "key": "shift+alt+left",
    //     "command": "cursorWordEndLeft"
    //     // Переместить курсор к концу слова слева
    // },
    
    // Поиск и hover
    {
        "key": "cmd+e",
        "command": "-actions.findWithSelection"
        // Отключение поиска выделенного текста
    },
    {
        "key": "cmd+e",
        "command": "editor.action.showHover",
        "when": "editorTextFocus"
        // Показать hover (подсказку) для текущего символа/слова
    },
    
    // Python/Jupyter - отключение выполнения кода
    {
        "key": "shift+enter",
        "command": "-jupyter.runcurrentcelladvance",
        "when": "editorTextFocus && jupyter.featureenabled && jupyter.hascodecells && !editorHasSelection"
        // Отключение выполнения ячейки Jupyter и перехода к следующей
    },
    {
        "key": "shift+enter",
        "command": "-jupyter.execSelectionInteractive",
        "when": "editorTextFocus && jupyter.featureenabled && jupyter.ownsSelection && !findInputFocussed && !replaceInputFocussed && editorLangId == 'python'"
        // Отключение интерактивного выполнения выделения в Jupyter
    },
    {
        "key": "shift+enter",
        "command": "-python.execSelectionInTerminal",
        "when": "editorTextFocus && !findInputFocussed && !python.datascience.ownsSelection && !replaceInputFocussed && editorLangId == 'python'"
        // Отключение выполнения выделенного кода Python в терминале
    },
    
    // Копирование путей файлов
    {
        "key": "cmd+l",
        "command": "copyRelativeFilePath"
        // Копировать относительный путь к файлу
    },
    {
        "key": "shift+alt+cmd+c",
        "command": "-copyRelativeFilePath",
        "when": "!editorFocus"
        // Отключение стандартного копирования относительного пути
    },
    {
        "key": "cmd+l",
        "command": "-expandLineSelection",
        "when": "editorFocus"
        // Отключение стандартного расширения выделения на всю строку (в редакторе)
    },
    {
        "key": "cmd+l",
        "command": "-expandLineSelection",
        "when": "textInputFocus"
        // Отключение стандартного расширения выделения на всю строку (в поле ввода)
    },
    
    // Навигация в полях ввода
    {
        "key": "ctrl+p",
        "command": "-cursorUp",
        "when": "textInputFocus"
        // Отключение перемещения курсора вверх в поле ввода
    },
    {
        "key": "ctrl+n",
        "command": "-cursorDown",
        "when": "textInputFocus"
        // Отключение перемещения курсора вниз в поле ввода
    },
    
    // Символы и вкладки окон
    {
        "key": "shift+cmd+r",
        "command": "-workbench.action.showAllSymbols"
        // Отключение показа всех символов
    },
    {
        "key": "cmd+]",
        "command": "workbench.action.showNextWindowTab"
        // Переключение на следующую вкладку окна
    },
    {
        "key": "cmd+[",
        "command": "workbench.action.showPreviousWindowTab"
        // Переключение на предыдущую вкладку окна
    },
    {
        "key": "cmd+[",
        "command": "-editor.action.outdentLines",
        "when": "editorTextFocus && !editorReadonly"
        // Отключение стандартного уменьшения отступа (Cmd+[ теперь для вкладок)
    },
    {
        "key": "cmd+]",
        "command": "-editor.action.indentLines",
        "when": "editorTextFocus && !editorReadonly"
        // Отключение стандартного увеличения отступа (Cmd+] теперь для вкладок)
    },
    
    // Разделение редактора - отключение стандартных комбинаций
    {
        "key": "cmd+k cmd+\\",
        "command": "-workbench.action.splitEditorOrthogonal"
        // Отключение ортогонального разделения редактора
    },
    {
        "key": "alt+cmd+2",
        "command": "-workbench.action.splitEditor"
        // Отключение разделения редактора (Alt+Cmd+2)
    },
    {
        "key": "cmd+k cmd+up",
        "command": "-workbench.action.splitEditor"
        // Отключение разделения редактора (Cmd+K Cmd+Up)
    },
    {
        "key": "cmd+\\",
        "command": "-workbench.action.splitEditor"
        // Отключение стандартного разделения редактора (Cmd+\)
    },
    {
        "key": "cmd+\\",
        "command": "-workbench.action.terminal.split",
        "when": "terminalFocus && terminalProcessSupported"
        // Отключение разделения терминала (Cmd+\)
    },
    {
        "key": "ctrl+shift+5",
        "command": "-workbench.action.terminal.split",
        "when": "terminalFocus && terminalProcessSupported"
        // Отключение разделения терминала (Ctrl+Shift+5)
    },
    
    // Python - дополнительные отключения выполнения
    {
        "key": "shift+enter",
        "command": "-python.execSelectionInTerminal",
        "when": "editorTextFocus && !findInputFocussed && !jupyter.ownsSelection && !notebookEditorFocused && !replaceInputFocussed && editorLangId == 'python'"
        // Отключение выполнения выделенного кода Python в терминале (дополнительное условие)
    },
    
    // Маркеры и навигация
    {
        "key": "cmd+k p",
        "command": "-editor.action.marker.prev",
        "when": "editorFocus"
        // Отключение перехода к предыдущему маркеру
    },
    {
        "key": "alt+cmd+p",
        "command": "-keybindings.editor.toggleSortByPrecedence",
        "when": "inKeybindings"
        // Отключение переключения сортировки по приоритету в редакторе горячих клавиш
    },
    {
        "key": "alt+cmd+p",
        "command": "-togglePreserveCase",
        "when": "editorFocus"
        // Отключение переключения сохранения регистра в редакторе
    },
    {
        "key": "alt+cmd+p",
        "command": "-toggleSearchPreserveCase",
        "when": "searchViewletFocus"
        // Отключение переключения сохранения регистра в поиске
    },
    {
        "key": "cmd+k p",
        "command": "-workbench.action.files.copyPathOfActiveFile"
        // Отключение копирования пути активного файла
    },
    
    // Quick Open - отключение навигации
    {
        "key": "cmd+p",
        "command": "-workbench.action.quickOpenNavigateNextInFilePicker",
        "when": "inFilesPicker && inQuickOpen"
        // Отключение навигации вперед в Quick Open
    },
    {
        "key": "shift+cmd+p",
        "command": "-workbench.action.quickOpenNavigatePreviousInFilePicker",
        "when": "inFilesPicker && inQuickOpen"
        // Отключение навигации назад в Quick Open
    },
    {
        "key": "cmd+p",
        "command": "-workbench.action.quickOpenPreviousEditor"
        // Отключение открытия предыдущего редактора через Quick Open
    },
    
    // Вставка строк
    {
        "key": "cmd+enter",
        "command": "-editor.action.insertLineAfter",
        "when": "editorTextFocus && !editorReadonly"
        // Отключение вставки строки после текущей
    },
    {
        "key": "shift+cmd+enter",
        "command": "-editor.action.insertLineBefore",
        "when": "editorTextFocus && !editorReadonly"
        // Отключение вставки строки перед текущей
    },
    {
        "key": "cmd+enter",
        "command": "-notebook.cell.insertCodeCellBelow",
        "when": "notebookCellListFocused && !inputFocus"
        // Отключение вставки ячейки кода ниже в ноутбуке
    },
    {
        "key": "cmd+enter",
        "command": "-search.action.openInEditor",
        "when": "hasSearchResult && searchViewletFocus"
        // Отключение открытия результата поиска в редакторе
    },
    {
        "key": "cmd+enter",
        "command": "-scm.acceptInput",
        "when": "scmRepository"
        // Отключение принятия ввода в SCM
    },
    {
        "key": "cmd+enter",
        "command": "-breadcrumbs.revealFocused",
        "when": "breadcrumbsActive && breadcrumbsVisible"
        // Отключение раскрытия фокусированных breadcrumbs
    },
    {
        "key": "cmd+enter",
        "command": "-breadcrumbs.revealFocusedFromTreeAside",
        "when": "breadcrumbsActive && breadcrumbsVisible && listFocus && !inputFocus"
        // Отключение раскрытия breadcrumbs из дерева
    },
    {
        "key": "cmd+enter",
        "command": "-debug.openBreakpointToSide",
        "when": "breakpointsFocused"
        // Отключение открытия точки останова сбоку
    },
    {
        "key": "cmd+enter",
        "command": "-workbench.action.submitComment",
        "when": "commentEditorFocused"
        // Отключение отправки комментария
    },
    {
        "key": "cmd+enter",
        "command": "-editor.action.replaceAll",
        "when": "editorFocus && findWidgetVisible && replaceInputFocussed"
        // Отключение замены всех вхождений
    },
    
    // Открытие файлов
    {
        "key": "cmd+o",
        "command": "-workbench.action.files.openFile",
        "when": "false"
        // Отключение открытия файла (всегда отключено)
    },
    {
        "key": "cmd+o",
        "command": "-workbench.action.files.openFileFolder",
        "when": "isMacNative && openFolderWorkspaceSupport"
        // Отключение открытия папки файла
    },
    {
        "key": "cmd+o",
        "command": "-workbench.action.files.openLocalFileFolder",
        "when": "remoteFileDialogVisible"
        // Отключение открытия локальной папки файла
    },
    
    // Форматирование
    {
        "key": "cmd+k cmd+f",
        "command": "-editor.action.formatSelection",
        "when": "editorHasDocumentSelectionFormattingProvider && editorTextFocus && !editorReadonly"
        // Отключение форматирования выделения
    },
    
    // Поиск в списках
    {
        "key": "cmd+f",
        "command": "-list.find",
        "when": "listFocus && listSupportsFind"
        // Отключение поиска в списке
    },
    
    // Терминал
    {
        "key": "cmd+w",
        "command": "-workbench.action.terminal.killEditor",
        "when": "terminalEditorFocus && terminalFocus && terminalHasBeenCreated || terminalEditorFocus && terminalFocus && terminalProcessSupported"
        // Отключение закрытия терминала в редакторе (старое поведение)
    },
    {
        "key": "cmd+w",
        "command": "workbench.action.terminal.kill",
        "when": "terminalEditorFocus || terminalFocus"
        // Закрыть терминал
    },
    
    // Python REPL - отключение выполнения
    {
        "key": "shift+enter",
        "command": "-python.execInREPL",
        "when": "config.python.REPL.sendToNativeREPL && editorTextFocus && !accessibilityModeEnabled && !jupyter.ownsSelection && !notebookEditorFocused && editorLangId == 'python' && activeEditor != 'workbench.editor.interactive'"
        // Отключение выполнения кода в Python REPL
    },
    {
        "key": "shift+enter",
        "command": "-python.execSelectionInTerminal",
        "when": "editorTextFocus && !findInputFocussed && !jupyter.ownsSelection && !notebookEditorFocused && !replaceInputFocussed && editorLangId == 'python' && activeEditor != 'workbench.editor.interactive'"
        // Отключение выполнения выделения в терминале (дополнительное условие)
    },
    {
        "key": "shift+enter",
        "command": "-notebook.cell.executeAndSelectBelow",
        "when": "notebookCellListFocused && !inlineChatFocused && notebookCellType == 'markup' || notebookCellListFocused && notebookMissingKernelExtension && !inlineChatFocused && !notebookCellExecuting && notebookCellType == 'code' || notebookCellListFocused && !inlineChatFocused && !notebookCellExecuting && notebookCellType == 'code' && notebookKernelCount > 0 || notebookCellListFocused && !inlineChatFocused && !notebookCellExecuting && notebookCellType == 'code' && notebookKernelSourceCount > 0"
        // Отключение выполнения ячейки ноутбука и выбора следующей
    },
    {
        "key": "shift+cmd+enter",
        "command": "-notebook.cell.insertCodeCellAbove",
        "when": "notebookCellListFocused && !inputFocus"
        // Отключение вставки ячейки кода выше в ноутбуке
    },
    {
        "key": "shift+enter",
        "command": "-workbench.action.terminal.findNext",
        "when": "terminalFindInputFocused && terminalHasBeenCreated || terminalFindInputFocused && terminalProcessSupported"
        // Отключение поиска следующего в терминале
    },
    
    // Поиск - отмена
    {
        "key": "cmd+f",
        "command": "search.action.cancel",
        "when": "listFocus && searchViewletVisible && !inputFocus && !treestickyScrollFocused && searchState != '0'"
        // Отменить поиск (когда фокус на списке результатов)
    },
    {
        "key": "escape",
        "command": "-search.action.cancel",
        "when": "listFocus && searchViewletVisible && !inputFocus && !treestickyScrollFocused && searchState != '0'"
        // Отключение отмены поиска по Escape
    },
    
    // Python - еще одно отключение выполнения
    {
        "key": "shift+enter",
        "command": "-python.execSelectionInTerminal",
        "when": "editorTextFocus && !findInputFocussed && !isCompositeNotebook && !jupyter.ownsSelection && !notebookEditorFocused && !replaceInputFocussed && editorLangId == 'python'"
        // Отключение выполнения выделения в терминале (еще одно условие)
    },
    {
        "key": "shift+enter",
        "command": "-python.execInREPL",
        "when": "config.python.REPL.sendToNativeREPL && editorTextFocus && !isCompositeNotebook && !jupyter.ownsSelection && !notebookEditorFocused && editorLangId == 'python'"
        // Отключение выполнения в REPL (еще одно условие)
    },
    
    // Hover и подсказки
    {
        "key": "cmd+k cmd+i",
        "command": "-list.showHover",
        "when": "listFocus && !inputFocus && !treestickyScrollFocused"
        // Отключение показа hover в списке
    },
    {
        "key": "cmd+i",
        "command": "-toggleSuggestionDetails",
        "when": "suggestWidgetHasFocusedSuggestion && suggestWidgetVisible && textInputFocus"
        // Отключение переключения деталей подсказок
    },
    
    // Определения типов и автодополнение
    {
        "key": "shift+cmd+t",
        "command": "editor.action.goToTypeDefinition"
        // Перейти к определению типа
    },
    // {
    //     "key": "ctrl+i",
    //     "command": "editor.action.triggerSuggest",
    //     "when": "editorHasCompletionItemProvider && textInputFocus && !editorReadonly && !suggestWidgetVisible"
    //     // Показать автодополнение (Ctrl+I)
    // },
    {
        "key": "cmd+i",
        "command": "-editor.action.triggerSuggest",
        "when": "editorHasCompletionItemProvider && textInputFocus && !editorReadonly && !suggestWidgetVisible"
        // Отключение показа автодополнения (Cmd+I)
    },
    
    // Быстрый поиск текста
    {
        "key": "ctrl+f",
        "command": "workbench.action.quickTextSearch"
        // Быстрый поиск текста в файле
    },
    {
        "key": "ctrl+f",
        "command": "-cursorRight",
        "when": "textInputFocus"
        // Отключение перемещения курсора вправо (Ctrl+F теперь для поиска)
    },
    
    // Панель и SCM
    {
        "key": "shift+cmd+t",
        "command": "workbench.action.toggleMaximizedPanel"
        // Переключить максимизацию панели (терминал/проблемы и т.д.)
    },
    {
        "key": "ctrl+shift+g",
        "command": "-workbench.view.scm",
        "when": "workbench.scm.active"
        // Отключение стандартного показа SCM
    },
    {
        "key": "alt+cmd+g",
        "command": "git.checkout"
        // Меню переключения веток в центре (как quick open), не панель SCM
    },
    {
        "key": "alt+cmd+b",
        "command": "-gitlens.toggleLineBlame",
        "when": "editorTextFocus"
        // Отвязка: Alt+Cmd+B в Cursor открывает браузер
    },
    {
        "key": "ctrl+alt+b",
        "command": "gitlens.toggleLineBlame",
        "when": "editorTextFocus"
        // GitLens: вкл/выкл blame аннотации по строкам
    },
    
    // Chat и AI функции - отключение
    {
        "key": "cmd+i",
        "command": "-workbench.action.chat.startVoiceChat",
        "when": "chatIsEnabled && hasSpeechProvider && inChatInput && !chatSessionRequestInProgress && !editorFocus && !notebookEditorFocused && !scopedVoiceChatGettingReady && !speechToTextInProgress || chatIsEnabled && hasSpeechProvider && inlineChatFocused && !chatSessionRequestInProgress && !editorFocus && !notebookEditorFocused && !scopedVoiceChatGettingReady && !speechToTextInProgress"
        // Отключение голосового чата
    },
    {
        "key": "ctrl+cmd+i",
        "command": "-workbench.action.chat.open",
        "when": "!chatSetupHidden"
        // Отключение открытия чата
    },
    {
        "key": "shift+cmd+i",
        "command": "-workbench.action.chat.openAgent",
        "when": "config.chat.agent.enabled && !chatSetupHidden"
        // Отключение открытия агента чата
    },
    {
        "key": "cmd+i",
        "command": "-workbench.action.chat.stopListeningAndSubmit",
        "when": "inChatInput && voiceChatInProgress && scopedVoiceChatInProgress == 'editor' || inChatInput && voiceChatInProgress && scopedVoiceChatInProgress == 'inline' || inChatInput && voiceChatInProgress && scopedVoiceChatInProgress == 'quick' || inChatInput && voiceChatInProgress && scopedVoiceChatInProgress == 'view' || inlineChatFocused && voiceChatInProgress && scopedVoiceChatInProgress == 'editor' || inlineChatFocused && voiceChatInProgress && scopedVoiceChatInProgress == 'inline' || inlineChatFocused && voiceChatInProgress && scopedVoiceChatInProgress == 'quick' || inlineChatFocused && voiceChatInProgress && scopedVoiceChatInProgress == 'view'"
        // Отключение остановки прослушивания и отправки в чате
    },
    {
        "key": "cmd+i",
        "command": "-inlineChat2.close",
